# Build artifacts from `task build` — native helper binaries land here.
/bin/jarvis-state
/bin/jarvis-cal
/bin/jarvis-when

# clift wrapper rendered by `task setup:cli` — generated, not source.
/bin/jarvis

# clift compiled flag/task cache (mtime-driven, regenerated on demand).
/.clift/

# go-task checksum cache for build:* idempotency.
/.task/

# Python bytecode caches (jarvis-when is a single-file script; runs uncached).
__pycache__/
*.pyc

# Rust cargo build artifacts.
/jarvis-cal/target/

# Claude Code workspace (prompts, plans, audits, memory) — never committed.
/.claude/
