# Build artifacts from `task build` — native helper binaries land here.
/bin/jarvis-state
/bin/jarvis-cal
/bin/jarvis-when

# go-task checksum cache for build:* idempotency.
/.task/

# Python bytecode caches (jarvis-when is a single-file script; runs uncached).
__pycache__/
*.pyc

# Rust cargo build artifacts.
/jarvis-cal/target/
