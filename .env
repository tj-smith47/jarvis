# jarvis .env — TEMPLATE FOR FRESH CLONES.
# `task setup:cli` overwrites CLI_DIR + FRAMEWORK_DIR with absolute paths
# during install. The committed CLI_DIR=. / FRAMEWORK_DIR=../.. only work
# from /opt/repos/jarvis next to /opt/repos/clift; on a real install at
# ~/.jarvis this is wrong until setup:cli runs.
# Tests don't read this file; they pass CLIFT_FRAMEWORK_DIR explicitly.
CLI_NAME=jarvis
CLI_VERSION=1.0.0
CLI_DIR=.
FRAMEWORK_DIR=../..
LOG_THEME=icons-color
CLIFT_MODE=standard
CFGD_VERSIONING=true
